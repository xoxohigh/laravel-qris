{
    "name": "fatwakb/laravel-qris",
    "description": "Production ready QRIS dynamic generator for Laravel 10/11/12 and native PHP",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "FatwaKB\\LaravelQRIS\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FatwaKB\\LaravelQRIS\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "endroid/qr-code": "^6.0",
        "khanamiryan/qrcode-detector-decoder": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^10.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "FatwaKB\\LaravelQRIS\\LaravelQRISServiceProvider"
            ],
            "aliases": {
                "QRIS": "FatwaKB\\LaravelQRIS\\Facades\\QRIS"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
